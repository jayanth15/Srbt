# Copy to .env and fill in values

# App
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# Dev (SQLite — default, leave blank to use SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./srbt_dev.db

# Prod (PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/srbt

# CORS (comma-separated)
CORS_ORIGINS=["http://localhost:3000","https://app.srbt.in"]
