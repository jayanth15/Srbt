---
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">SR</span>
          </div>
          <div>
            <p class="text-white font-bold text-sm leading-tight">Sri Raghavendra</p>
            <p class="text-gray-400 text-xs leading-tight">Blue Metals & Transport</p>
          </div>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">
          Trusted supplier of quality blue metal aggregates and reliable transport services across the region.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About Us' },
            { href: '/services', label: 'Services' },
            { href: '/gallery', label: 'Gallery' },
            { href: '/contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="hover:text-blue-400 transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-2 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Tamil Nadu, India</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+91XXXXXXXXXX" class="hover:text-blue-400 transition-colors">+91 XXXXXXXXXX</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@srbt.in" class="hover:text-blue-400 transition-colors">info@srbt.in</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>&copy; {new Date().getFullYear()} Sri Raghavendra Blue Metals & Transport. All rights reserved.</p>
      <a
        href="https://app.srbt.in"
        target="_blank"
        rel="noopener noreferrer"
        class="text-blue-400 hover:text-blue-300 transition-colors font-medium"
      >
        Go to App Portal →
      </a>
    </div>
  </div>
</footer>
