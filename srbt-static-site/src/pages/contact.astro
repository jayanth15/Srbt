---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact" description="Get in touch with SRBT for blue metal aggregate orders and transport enquiries.">
  <Header />
  <main>
    <section class="bg-blue-800 text-white py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-extrabold mb-3">Contact Us</h1>
        <p class="text-blue-200 text-lg">We're here to help with your enquiries and orders.</p>
      </div>
    </section>
    <ContactForm />
  </main>
  <Footer />
</BaseLayout>
