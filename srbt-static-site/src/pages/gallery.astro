---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Gallery from '../components/Gallery.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Gallery" description="Photos of SRBT operations — quarry, aggregates, fleet, and deliveries.">
  <Header />
  <main>
    <section class="bg-blue-800 text-white py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-extrabold mb-3">Gallery</h1>
        <p class="text-blue-200 text-lg">Our operations in pictures.</p>
      </div>
    </section>
    <Gallery />
  </main>
  <Footer />
</BaseLayout>
